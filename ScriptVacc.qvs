
// ============================================================
// MODELLO DATI - VACCINAZIONI (STRUTTURA A STELLA VELOCE)
// Una sola FACT table + 2 dimensioni
// ============================================================

// ============================================================
// STEP 1 - CARICAMENTO RAW
// ============================================================

[_Raw_Somm]:
LOAD
    ID_ASSISTITO_GIAVA, CODANTIGENE, DOSE, DATASOMMINISTRAZIONE,
    CODICEAICVACCINO, CAPITALIZE(DENOMVACCINO) AS DENOMVACCINO, CODICESTRUTTURA, TIPOEROGATORE,
    CODCONDIZIONESANITARIA, CODCATEGORIARISCHIO, LOTTOVACCINO,
    DATASCADENZA, MODALITAPAGAMENTO, SITOINOCULAZIONE,
    COMUNESOMMINISTRAZIONE, ASLSOMMINISTRAZIONE, REGIONESOMMINISTRAZIONE,
    STATOESTEROSOMMINISTRAZIONE
FROM [lib://Qlik_Dati_Basilicata/EIMaS/01.Sanitario/02.Qlik/QV_Associative/VaccinazioniSomministrate.qvd]
(qvd)
WHERE Year(DATASOMMINISTRAZIONE) >= Year(Today()) - 3;

[_Raw_Mancate]:
LOAD
    ID_ASSISTITO_GIAVA, CODANTIGENE, DOSE,
    DATANONEFFETTUAZIONE, MOTIVAZIONE
FROM [lib://Qlik_Dati_Basilicata/EIMaS/01.Sanitario/02.Qlik/QV_Associative/VaccinazioniMancate.qvd]
(qvd)
WHERE Year(DATANONEFFETTUAZIONE) >= Year(Today()) - 3;


// ============================================================
// STEP 2 - MAPPE DA ANAGRAFICA ASSISTITI
// ============================================================

[Map_ComuneResidenza]:   
MAPPING LOAD ID_ASSISTITO_GIAVA, Right('000000' & Text(COMUNERESIDENZA), 6)  
FROM [lib://Qlik_Dati_Basilicata/EIMaS/01.Sanitario/01.Datafile/Vaccinazioni/AnagraficaAVN_output.csv]
(txt, utf8, embedded labels, delimiter is ';', msq);

[Map_ComuneDomicilio]:   
MAPPING LOAD ID_ASSISTITO_GIAVA, Right('000000' & Text(COMUNEDOMICILIO), 6) 
FROM [lib://Qlik_Dati_Basilicata/EIMaS/01.Sanitario/01.Datafile/Vaccinazioni/AnagraficaAVN_output.csv]
(txt, utf8, embedded labels, delimiter is ';', msq);

[Map_ASLResidenza]:      
MAPPING LOAD ID_ASSISTITO_GIAVA, ASLRESIDENZA    
FROM [lib://Qlik_Dati_Basilicata/EIMaS/01.Sanitario/01.Datafile/Vaccinazioni/AnagraficaAVN_output.csv]
(txt, utf8, embedded labels, delimiter is ';', msq);

[Map_ASLDomicilio]:      
MAPPING LOAD ID_ASSISTITO_GIAVA, ASLDOMICILIO      
FROM [lib://Qlik_Dati_Basilicata/EIMaS/01.Sanitario/01.Datafile/Vaccinazioni/AnagraficaAVN_output.csv]
(txt, utf8, embedded labels, delimiter is ';', msq);

[Map_RegioneResidenza]:  
MAPPING LOAD ID_ASSISTITO_GIAVA, REGIONERESIDENZA 
FROM [lib://Qlik_Dati_Basilicata/EIMaS/01.Sanitario/01.Datafile/Vaccinazioni/AnagraficaAVN_output.csv]
(txt, utf8, embedded labels, delimiter is ';', msq);

[Map_RegioneDomicilio]:  
MAPPING LOAD ID_ASSISTITO_GIAVA, REGIONEDOMICILIO  
FROM [lib://Qlik_Dati_Basilicata/EIMaS/01.Sanitario/01.Datafile/Vaccinazioni/AnagraficaAVN_output.csv]
(txt, utf8, embedded labels, delimiter is ';', msq);


// ============================================================
// STEP 3 - MAPPE DESCRITTIVE (comuni, ASL, regioni da file)
// ============================================================

[Map_ComuneDes]:
MAPPING LOAD DISTINCT
    Right('000000' & Text(CodComuneResidenza), 6),
    DenComune
FROM [lib://Qlik_Dati_Basilicata/EIMaS/01.Sanitario/01.Datafile/Anagrafiche/EXT_ANAG_Comuni.qvd]
(qvd);

// [Map_ASLDes]:
// MAPPING LOAD DISTINCT
//     "CODICE REGIONE" & "CODICE AZIENDA",
//     Capitalize("DENOMINAZIONE AZIENDA")
// FROM [lib://Qlik_Dati_Basilicata/EIMaS/01.Sanitario/01.Datafile/Anagrafiche/ASL 2010-2025.csv]
// (txt, codepage is 28591, embedded labels, delimiter is ';', msq);

[Map_ASLDes]:
load * inline [
Codice, Descrizione
170201, "ASL Potenza"
170202, "ASL Matera"
170901, "AO San Carlo"
170902, "IRCCS CROB"
170910, "IRCCS CROB];



[Map_RegioneDes]:
MAPPING LOAD DISTINCT
    Codice,
    Descrizione
FROM [lib://Qlik_Dati_Basilicata/EIMaS/01.Sanitario/01.Datafile/Anagrafiche/EXT_ANAG_Regioni.qvd]
(qvd);


// ============================================================
// STEP 4 - MAPPE DESCRITTIVE (INLINE)
// ============================================================

[Map_TipoErogatore]:
MAPPING LOAD * INLINE [
Valore, Descrizione
0, Istituto di ricovero pubblico o privato
1, Altra struttura sanitaria pubblica o privata accreditata 
2, Centro vaccinale
3, Medico di Medicina Generale (MMG)
4, Pediatra di Libera Scelta (PLS)
5, Specialista
6, Altro
7, Struttura privata autorizzata non accreditata SSN
8, Struttura di riabilitazione
9, Strutture che non effettuano attività sanitaria
10, Struttura Militare
11, Ambulatorio nei luoghi di lavoro
12, Farmacia
99, Dato non disponibile
];

[Map_CondizioniSanitarie]:
MAPPING LOAD * INLINE [
Codice, Descrizione
00, Nessuna condizione
01, Alcoolismo cronico
02, Asplenia anatomica o funzionale e candidati alla splenectomia
03, BPCO
04, Chemioterapia o radioterapia
